{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/hero_banner.webp",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/hero_banner.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/servicos/:slug",
      "destination": "/servicos/:slug.html"
    },
    {
      "source": "/blog/:slug",
      "destination": "/pages/blog/:slug.html"
    },
    {
      "source": "/blog/:slug.html",
      "destination": "/pages/blog/:slug.html"
    },
    {
      "source": "/areas-atendidas/:slug",
      "destination": "/areas-atendidas/:slug.html"
    }
  ]
}
